{
  "name": "rightmove-investor-assistant",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Rightmove Companion — local Chrome extension for costs, finance, rent context, and buy-to-let tools on Rightmove for-sale listings.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jzhen648-creator/rightmove-companion.git"
  },
  "homepage": "https://github.com/jzhen648-creator/rightmove-companion#readme",
  "scripts": {
    "build": "vite build",
    "build:store": "vite build --mode store",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.check.json",
    "icons": "node scripts/generate-icons.js",
    "lint": "eslint src"
  },
  "dependencies": {
    "linkedom": "^0.18.12",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@resvg/resvg-js": "^2.6.2",
    "@types/chrome": "^0.0.299",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.0.0"
  }
}
