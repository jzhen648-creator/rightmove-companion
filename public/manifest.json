{
  "manifest_version": 3,
  "name": "Rightmove Companion",
  "description": "Costs, finance, rent context, and buy-to-let tools on Rightmove for-sale listings.",
  "version": "1.0.0",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.rightmove.co.uk/*",
    "https://www.zoopla.co.uk/*",
    "https://www.primelocation.com/*",
    "https://landregistry.data.gov.uk/*",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "assets/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.rightmove.co.uk/properties/*",
        "https://www.rightmove.co.uk/property-for-sale/*"
      ],
      "js": ["assets/content.js"],
      "run_at": "document_idle"
    }
  ]
}
